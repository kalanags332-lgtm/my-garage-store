<div class="admin-header">
  <div>
    <h1><%= isAdmin ? 'Admin Dashboard' : 'Seller Dashboard' %></h1>
    <% if (seller) { %>
      <p class="seller-subtitle">
        Welcome, <strong><%= seller.displayName %></strong>
        <% if (seller.storeName) { %> · <em><%= seller.storeName %></em><% } %>
      </p>
    <% } %>
  </div>
  <div class="header-actions">
    <a href="/seller/items/new" class="btn btn-primary">+ Add Item</a>
    <% if (isAdmin) { %>
      <a href="/seller/sellers" class="btn btn-outline">Manage Sellers</a>
    <% } %>
  </div>
</div>

<!-- Stats Strip -->
<div class="stats-strip">
  <div class="stat-card">
    <span class="stat-num"><%= items.length %></span>
    <span class="stat-label">Total Items</span>
  </div>
  <div class="stat-card">
    <span class="stat-num"><%= items.filter(i => !i.sold).length %></span>
    <span class="stat-label">Available</span>
  </div>
  <div class="stat-card">
    <span class="stat-num"><%= items.filter(i => i.sold).length %></span>
    <span class="stat-label">Sold</span>
  </div>
  <div class="stat-card">
    <span class="stat-num"><%= inquiries.length %></span>
    <span class="stat-label">Inquiries</span>
  </div>
  <% if (unreadCount > 0) { %>
    <div class="stat-card stat-card--alert">
      <span class="stat-num"><%= unreadCount %></span>
      <span class="stat-label">Unread</span>
    </div>
  <% } %>
</div>

<!-- Items table -->
<section class="admin-section">
  <h2>My Items (<%= items.length %>)</h2>
  <% if (items.length === 0) { %>
    <p class="empty-state">No items yet. <a href="/seller/items/new">Add your first item</a>.</p>
  <% } else { %>
    <div class="table-wrap">
      <table class="admin-table">
        <thead>
          <tr>
            <th>Photo</th>
            <th>Title</th>
            <th>Price</th>
            <th>Category</th>
            <th>Condition</th>
            <% if (isAdmin) { %><th>Seller</th><% } %>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% items.forEach(item => { %>
            <tr class="<%= item.sold ? 'row-sold' : '' %>">
              <td>
                <% if (item.images.length > 0) { %>
                  <img src="<%= item.images[0] %>" alt="" class="table-thumb" />
                <% } else { %>
                  <div class="table-thumb no-img">—</div>
                <% } %>
              </td>
              <td><a href="/items/<%= item._id %>" target="_blank"><%= item.title %></a></td>
              <td>LKR <%= item.price.toFixed(2) %></td>
              <td><%= item.category %></td>
              <td><%= item.condition %></td>
              <% if (isAdmin) { %>
                <td><%= item.seller ? item.seller.displayName : '—' %></td>
              <% } %>
              <td>
                <span class="badge <%= item.sold ? 'badge--sold' : 'badge--available' %>">
                  <%= item.sold ? 'Sold' : 'Available' %>
                </span>
              </td>
              <td class="action-btns">
                <a href="/seller/items/<%= item._id %>/edit" class="btn btn-sm">Edit</a>
                <form action="/seller/items/<%= item._id %>/toggle-sold" method="POST" style="display:inline">
                  <button class="btn btn-sm btn-outline"><%= item.sold ? 'Mark Available' : 'Mark Sold' %></button>
                </form>
                <form action="/seller/items/<%= item._id %>/delete" method="POST" style="display:inline"
                      onsubmit="return confirm('Delete this item?')">
                  <button class="btn btn-sm btn-danger">Delete</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</section>

<!-- Inquiries -->
<section class="admin-section">
  <h2>Buyer Inquiries (<%= inquiries.length %>)<% if (unreadCount > 0) { %> <span class="badge badge--new"><%= unreadCount %> new</span><% } %></h2>
  <% if (inquiries.length === 0) { %>
    <p class="empty-state">No inquiries yet.</p>
  <% } else { %>
    <div class="table-wrap">
      <table class="admin-table">
        <thead>
          <tr><th>Date</th><th>Item</th><th>From</th><th>Message</th><th>Actions</th></tr>
        </thead>
        <tbody>
          <% inquiries.forEach(inq => { %>
            <tr class="<%= !inq.read ? 'row-unread' : '' %>">
              <td><%= inq.createdAt.toLocaleDateString() %></td>
              <td><%= inq.itemTitle %></td>
              <td>
                <strong><%= inq.name %></strong><br/>
                <a href="mailto:<%= inq.email %>"><%= inq.email %></a>
                <% if (inq.phone) { %><br/><%= inq.phone %><% } %>
              </td>
              <td class="msg-cell"><%= inq.message %></td>
              <td class="action-btns">
                <% if (!inq.read) { %>
                  <form action="/seller/inquiries/<%= inq._id %>/read" method="POST" style="display:inline">
                    <button class="btn btn-sm">Mark Read</button>
                  </form>
                <% } %>
                <form action="/seller/inquiries/<%= inq._id %>/delete" method="POST" style="display:inline"
                      onsubmit="return confirm('Delete this inquiry?')">
                  <button class="btn btn-sm btn-danger">Delete</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</section>
