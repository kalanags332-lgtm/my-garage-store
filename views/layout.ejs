<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> — My Garage Store</title>
  <link rel="icon" href="/favicon.png" type="image/png" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <header class="site-header">
    <div class="container">
      <a href="/" class="logo">🏠 My Garage Store</a>
      <nav>
        <a href="/">Browse</a>
        <% if (isSeller) { %>
          <a href="/seller/dashboard">My Dashboard</a>
          <a href="/seller/profile">My Profile</a>
          <% if (isAdmin) { %>
            <a href="/seller/sellers">Manage Sellers</a>
          <% } %>
          <form action="/seller/logout" method="POST" style="display:inline">
            <button type="submit" class="btn-link">Logout (<%= sellerName %>)</button>
          </form>
        <% } else { %>
          <a href="/seller/login" class="nav-seller-link">Seller Login</a>
          <a href="/seller/register" class="btn btn-sm btn-primary">Become a Seller</a>
        <% } %>
      </nav>
    </div>
  </header>

  <main class="container">
    <%- body %>
  </main>

  <footer class="site-footer">
    <div class="container">
      <p>All items are used and sold as-is. Contact the seller for more info.</p>
    </div>
  </footer>

  <script src="/js/main.js"></script>
</body>
</html>
